{
  "name": "twitter-gallery",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build && node -e \"require('fs').copyFileSync('data/demo-data.json','dist/demo-data.json')\"",
    "preview": "vite preview",
    "server": "node backend/index.js",
    "start": "concurrently \"pnpm run server\" \"pnpm run dev\"",
    "pm2:start": "pnpm run build && pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:startup": "pm2-startup install && pm2 save"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "axios": "^1.16.1",
    "hls.js": "^1.6.16",
    "vue": "^3.5.34",
    "vue-next-masonry": "^1.1.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.14",
    "puppeteer": "^25.0.4",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12"
  }
}
